    "id": {
      "dtype": "string",
      "_type": "Value"
    },
    "tokens": {
      "feature": {
        "dtype": "string",
        "_type": "Value"
      },
      "_type": "Sequence"
    },
    "ner_tags": {
      "feature": {
        "dtype": "string",
        "_type": "Value"
      },
      "_type": "Sequence"
    },
    "ner_tag_ids": {
      "feature": {
        "names": [
          "O",
          "B-MULTA",
          "I-MULTA",
          "B-OBRIGACAO",
          "I-OBRIGACAO",
          "B-RESSARCIMENTO",
          "I-RESSARCIMENTO",
          "B-RECOMENDACAO",
          "I-RECOMENDACAO"
        ],
        "_type": "ClassLabel"
      },
      "_type": "Sequence"
    },
    "token_offsets": {
      "feature": {
        "feature": {
          "dtype": "int32",
          "_type": "Value"
        },
        "_type": "Sequence"
      },
      "_type": "Sequence"
    },
    "text": {
      "dtype": "string",
      "_type": "Value"
    },
    "spans": [
