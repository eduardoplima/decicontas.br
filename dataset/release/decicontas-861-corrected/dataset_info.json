          "dtype": "int32",
          "_type": "Value"
        },
        "label": {
          "dtype": "string",
          "_type": "Value"
        }
      }
    ]
  },
  "label_names": [
    "O",
    "B-MULTA",
    "I-MULTA",
    "B-OBRIGACAO",
    "I-OBRIGACAO",
    "B-RESSARCIMENTO",
    "I-RESSARCIMENTO",
    "B-RECOMENDACAO",
    "I-RECOMENDACAO"
  ],
  "entity_types": [
